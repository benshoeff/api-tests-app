generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Environment {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  baseUrl   String?
  color     String   @default("blue")
  isDefault Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variableValues EnvironmentValue[]
  testRuns       TestRun[]
}

model GlobalVariable {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  values EnvironmentValue[]
}

model EnvironmentValue {
  id            String @id @default(cuid())
  value         String
  variableId    String
  environmentId String

  variable    GlobalVariable @relation(fields: [variableId], references: [id], onDelete: Cascade)
  environment Environment    @relation(fields: [environmentId], references: [id], onDelete: Cascade)

  @@unique([variableId, environmentId])
}

model SharedStep {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items SharedStepItem[]
}

model SharedStepItem {
  id           String @id @default(cuid())
  sharedStepId String
  sortOrder    Int
  type         String
  config       Json

  sharedStep SharedStep @relation(fields: [sharedStepId], references: [id], onDelete: Cascade)
}

model Test {
  id             String   @id @default(cuid())
  name           String
  description    String?
  timeoutMs      Int      @default(30000)
  environmentIds Json     @default("[]")
  tags           Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  steps     TestStep[]
  runs      TestRun[]
  variables TestVariable[]
  schedule  TestSchedule?
}

model TestVariable {
  id     String @id @default(cuid())
  testId String
  key    String
  value  String

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([testId, key])
}

model TestSchedule {
  id         String  @id @default(cuid())
  testId     String  @unique
  active     Boolean @default(false)
  interval   Int     @default(1)
  unit       String  @default("days")
  runAtTime  Boolean @default(false)
  time       String?
  timezone   String  @default("UTC")
  days       Json    @default("[]")

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model TestStep {
  id        String @id @default(cuid())
  testId    String
  sortOrder Int
  type      String
  config    Json

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)
}

model TestRun {
  id            String    @id @default(cuid())
  testId        String
  environmentId String
  status        String    @default("pending")
  runType       String    @default("manual")
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  durationMs    Int?

  test        Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  environment Environment @relation(fields: [environmentId], references: [id])
  stepResults StepResult[]
}

model StepResult {
  id           String  @id @default(cuid())
  runId        String
  stepIndex    Int
  stepType     String
  status       String
  durationMs   Int?
  request      Json?
  response     Json?
  assertions   Json?
  errorMessage String?

  run TestRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}
